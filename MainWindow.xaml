<Window
    x:Class="Calender.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Calender">

    <!-- Backdrop is set programmatically so IsInputActive stays true even on blur. -->

    <NavigationView
        x:Name="NavView"
        PaneDisplayMode="Left"
        IsSettingsVisible="True"
        IsPaneToggleButtonVisible="True"
        SelectionChanged="NavView_SelectionChanged"
        Loaded="NavView_Loaded">

        <NavigationView.MenuItems>
            <NavigationViewItem Content="Calendar" Tag="CalendarPage">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE787;"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Agenda" Tag="AgendaPage">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE8A5;"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <!-- Pane footer: widget toggle -->
        <NavigationView.PaneFooter>
            <NavigationViewItem
                x:Name="WidgetToggleItem"
                Content="Widget"
                SelectsOnInvoked="False"
                Tapped="WidgetToggle_Tapped"
                ToolTipService.ToolTip="Toggle calendar widget">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE78B;"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.PaneFooter>

        <!-- Primary content frame -->
        <Frame x:Name="ContentFrame" Background="Transparent"/>

    </NavigationView>
</Window>
