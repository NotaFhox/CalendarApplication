<Application
    x:Class="Calender.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:Calender.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Required for WinUI 3 default control styles -->
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Value converters used across pages -->
            <conv:BoolToAccentBrushConverter  x:Key="BoolToAccentBrushConverter"/>
            <conv:BoolToOpacityConverter      x:Key="BoolToOpacityConverter"/>
            <conv:StringToColorConverter      x:Key="StringToColorConverter"/>
            <conv:BoolToVisibilityConverter   x:Key="BoolToVisibilityConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
