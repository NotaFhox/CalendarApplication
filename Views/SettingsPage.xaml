<Page
    x:Class="Calender.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24,16,24,40" Spacing="4" MaxWidth="640" HorizontalAlignment="Left">

            <TextBlock
                Text="Settings"
                Style="{StaticResource TitleLargeTextBlockStyle}"
                Margin="0,0,0,20"/>

            <TextBlock
                Text="APPEARANCE"
                FontSize="11"
                FontWeight="SemiBold"
                Opacity="0.45"
                CharacterSpacing="60"
                Margin="0,8,0,6"/>

            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="Theme" FontSize="14"/>
                        <TextBlock
                            Text="Choose your preferred colour scheme"
                            FontSize="12"
                            Opacity="0.55"/>
                    </StackPanel>
                    <ComboBox
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        MinWidth="160"
                        SelectedIndex="{x:Bind ViewModel.SelectedThemeIndex, Mode=TwoWay}">
                        <ComboBoxItem Content="System default"/>
                        <ComboBoxItem Content="Light"/>
                        <ComboBoxItem Content="Dark"/>
                    </ComboBox>
                </Grid>
            </Border>

            <TextBlock
                Text="SOUND"
                FontSize="11"
                FontWeight="SemiBold"
                Opacity="0.45"
                CharacterSpacing="60"
                Margin="0,20,0,6"/>

            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="Sound effects" FontSize="14"/>
                        <TextBlock
                            Text="Play sounds on interactions and event actions"
                            FontSize="12"
                            Opacity="0.55"/>
                    </StackPanel>
                    <ToggleSwitch
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsOn="{x:Bind ViewModel.SoundEnabled, Mode=TwoWay}"
                        OnContent=""
                        OffContent=""
                        Margin="12,0,-8,0"/>
                </Grid>
            </Border>

            <TextBlock
                Text="WIDGET"
                FontSize="11"
                FontWeight="SemiBold"
                Opacity="0.45"
                CharacterSpacing="60"
                Margin="0,20,0,6"/>

            <TextBlock
                Text="Changes to widget settings apply when the widget is next opened."
                FontSize="12"
                Opacity="0.45"
                Margin="0,0,0,4"/>

            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8 8 0 0"
                Padding="16,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="Always on top" FontSize="14"/>
                        <TextBlock
                            Text="Keep the widget above all other windows by default"
                            FontSize="12"
                            Opacity="0.55"/>
                    </StackPanel>
                    <ToggleSwitch
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsOn="{x:Bind ViewModel.WidgetAlwaysOnTop, Mode=TwoWay}"
                        OnContent=""
                        OffContent=""
                        Margin="12,0,-8,0"/>
                </Grid>
            </Border>

            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1,0,1,1"
                CornerRadius="0 0 8 8"
                Padding="16,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="Default size" FontSize="14"/>
                        <TextBlock
                            Text="The size the widget opens in"
                            FontSize="12"
                            Opacity="0.55"/>
                    </StackPanel>
                    <ToggleSwitch
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsOn="{x:Bind ViewModel.WidgetSizeLarge, Mode=TwoWay}"
                        OnContent="Full"
                        OffContent="Compact"
                        Margin="12,0,-8,0"/>
                </Grid>
            </Border>

            <TextBlock
                Text="ABOUT"
                FontSize="11"
                FontWeight="SemiBold"
                Opacity="0.45"
                CharacterSpacing="60"
                Margin="0,20,0,6"/>

            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8 8 0 0"
                Padding="16,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="Calendar" FontSize="14"/>
                        <TextBlock
                            Text="WinUI 3 &#x00B7; Windows App SDK 1.8 &#x00B7; .NET 9"
                            FontSize="12"
                            Opacity="0.55"/>
                    </StackPanel>
                    <TextBlock
                        Grid.Column="1"
                        Text="{x:Bind ViewModel.AppVersion}"
                        FontSize="13"
                        Opacity="0.55"
                        VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1,0,1,1"
                CornerRadius="0 0 8 8"
                Padding="16,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="Data folder" FontSize="14"/>
                        <TextBlock
                            Text="{x:Bind ViewModel.DataFolder}"
                            FontSize="11"
                            Opacity="0.45"
                            TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <Button
                        Grid.Column="1"
                        Content="Open"
                        Command="{x:Bind ViewModel.OpenDataFolderCommand}"
                        Padding="12,6"
                        VerticalAlignment="Center"/>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
