<Page
    x:Class="Calender.Views.SmallWidgetView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Calender.Models"
    Background="Transparent">

    <StackPanel Padding="14,6,14,14" Spacing="10">

        <!-- ── Large date display ─────────────────────────────────────────── -->
        <StackPanel>
            <TextBlock
                Text="{x:Bind ViewModel.DayName, Mode=OneWay}"
                FontSize="11"
                FontWeight="SemiBold"
                Opacity="0.55"
                CharacterSpacing="60"/>
            <TextBlock
                Text="{x:Bind ViewModel.Today.Day, Mode=OneWay}"
                FontSize="52"
                FontWeight="Light"
                LineHeight="54"
                Margin="0,-2,0,0"/>
            <TextBlock
                Text="{x:Bind ViewModel.MonthYear, Mode=OneWay}"
                FontSize="12"
                Opacity="0.55"/>
        </StackPanel>

        <!-- ── Divider ───────────────────────────────────────────────────── -->
        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

        <!-- ── Today's events ────────────────────────────────────────────── -->
        <StackPanel Spacing="4">
            <TextBlock
                Text="TODAY"
                FontSize="10"
                FontWeight="SemiBold"
                Opacity="0.45"
                CharacterSpacing="60"/>

            <TextBlock
                Text="No events today"
                FontSize="11"
                Opacity="0.35"
                Margin="0,2,0,0"
                Visibility="{x:Bind ViewModel.HasNoTodayEvents,
                    Converter={StaticResource BoolToVisibilityConverter},
                    Mode=OneWay}"/>

            <ItemsRepeater ItemsSource="{x:Bind ViewModel.TodayEvents, Mode=OneWay}">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:CalendarEvent">
                        <StackPanel Orientation="Horizontal" Spacing="7" Margin="0,2">
                            <Ellipse
                                Width="6" Height="6"
                                VerticalAlignment="Center"
                                Fill="{x:Bind Color, Converter={StaticResource StringToColorConverter}}"/>
                            <TextBlock
                                Text="{x:Bind Title}"
                                FontSize="12"
                                TextTrimming="CharacterEllipsis"
                                MaxLines="1"
                                VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </StackPanel>

        <!-- ── Upcoming ──────────────────────────────────────────────────── -->
        <StackPanel Spacing="4">
            <TextBlock
                Text="UPCOMING"
                FontSize="10"
                FontWeight="SemiBold"
                Opacity="0.45"
                CharacterSpacing="60"/>

            <TextBlock
                Text="Nothing coming up"
                FontSize="11"
                Opacity="0.35"
                Margin="0,2,0,0"
                Visibility="{x:Bind ViewModel.HasNoUpcomingEvents,
                    Converter={StaticResource BoolToVisibilityConverter},
                    Mode=OneWay}"/>

            <ItemsRepeater ItemsSource="{x:Bind ViewModel.UpcomingEvents, Mode=OneWay}">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:CalendarEvent">
                        <StackPanel Orientation="Horizontal" Spacing="7" Margin="0,2">
                            <Ellipse
                                Width="6" Height="6"
                                VerticalAlignment="Center"
                                Fill="{x:Bind Color, Converter={StaticResource StringToColorConverter}}"/>
                            <TextBlock
                                Text="{x:Bind Title}"
                                FontSize="12"
                                TextTrimming="CharacterEllipsis"
                                MaxLines="1"
                                VerticalAlignment="Center"
                                Opacity="0.75"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </StackPanel>

    </StackPanel>
</Page>
