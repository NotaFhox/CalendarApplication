<ContentDialog
    x:Class="Calender.Views.EventEditorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    PrimaryButtonText="Save"
    CloseButtonText="Cancel"
    DefaultButton="Primary">

    <ScrollViewer MaxHeight="540" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="14" Width="380" Padding="0,4,0,4">

            <!-- Title -->
            <TextBox
                Header="Title"
                Text="{x:Bind ViewModel.Title, Mode=TwoWay}"
                PlaceholderText="Add a title"/>

            <!-- All day toggle -->
            <ToggleSwitch
                Header="All day"
                IsOn="{x:Bind ViewModel.IsAllDay, Mode=TwoWay}"
                OnContent="Yes" OffContent="No"/>

            <!-- Start date + time -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <DatePicker
                    Grid.Column="0"
                    Header="Starts"
                    Date="{x:Bind ViewModel.StartDate, Mode=TwoWay}"/>
                <TimePicker
                    Grid.Column="1"
                    Header=" "
                    Time="{x:Bind ViewModel.StartTime, Mode=TwoWay}"
                    Visibility="{x:Bind ViewModel.IsAllDay,
                        Converter={StaticResource BoolToVisibilityConverter},
                        ConverterParameter=Invert, Mode=OneWay}"/>
            </Grid>

            <!-- End date + time -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <DatePicker
                    Grid.Column="0"
                    Header="Ends"
                    Date="{x:Bind ViewModel.EndDate, Mode=TwoWay}"/>
                <TimePicker
                    Grid.Column="1"
                    Header=" "
                    Time="{x:Bind ViewModel.EndTime, Mode=TwoWay}"
                    Visibility="{x:Bind ViewModel.IsAllDay,
                        Converter={StaticResource BoolToVisibilityConverter},
                        ConverterParameter=Invert, Mode=OneWay}"/>
            </Grid>

            <!-- Description -->
            <TextBox
                Header="Description"
                Text="{x:Bind ViewModel.Description, Mode=TwoWay}"
                PlaceholderText="Add a description"
                AcceptsReturn="True"
                TextWrapping="Wrap"
                Height="72"/>

            <!-- Location -->
            <TextBox
                Header="Location"
                Text="{x:Bind ViewModel.Location, Mode=TwoWay}"
                PlaceholderText="Add a location"/>

            <!-- Color swatches -->
            <StackPanel Spacing="6">
                <TextBlock
                    Text="Color"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Padding="2" Background="Transparent" BorderThickness="0"
                            Command="{x:Bind ViewModel.SelectColorCommand}"
                            CommandParameter="#0078D4"
                            ToolTipService.ToolTip="Blue">
                        <Border Width="26" Height="26" CornerRadius="13" Background="#0078D4"/>
                    </Button>
                    <Button Padding="2" Background="Transparent" BorderThickness="0"
                            Command="{x:Bind ViewModel.SelectColorCommand}"
                            CommandParameter="#107C10"
                            ToolTipService.ToolTip="Green">
                        <Border Width="26" Height="26" CornerRadius="13" Background="#107C10"/>
                    </Button>
                    <Button Padding="2" Background="Transparent" BorderThickness="0"
                            Command="{x:Bind ViewModel.SelectColorCommand}"
                            CommandParameter="#D13438"
                            ToolTipService.ToolTip="Red">
                        <Border Width="26" Height="26" CornerRadius="13" Background="#D13438"/>
                    </Button>
                    <Button Padding="2" Background="Transparent" BorderThickness="0"
                            Command="{x:Bind ViewModel.SelectColorCommand}"
                            CommandParameter="#FFB900"
                            ToolTipService.ToolTip="Yellow">
                        <Border Width="26" Height="26" CornerRadius="13" Background="#FFB900"/>
                    </Button>
                    <Button Padding="2" Background="Transparent" BorderThickness="0"
                            Command="{x:Bind ViewModel.SelectColorCommand}"
                            CommandParameter="#744DA9"
                            ToolTipService.ToolTip="Purple">
                        <Border Width="26" Height="26" CornerRadius="13" Background="#744DA9"/>
                    </Button>
                    <Button Padding="2" Background="Transparent" BorderThickness="0"
                            Command="{x:Bind ViewModel.SelectColorCommand}"
                            CommandParameter="#EA005E"
                            ToolTipService.ToolTip="Pink">
                        <Border Width="26" Height="26" CornerRadius="13" Background="#EA005E"/>
                    </Button>
                </StackPanel>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</ContentDialog>
