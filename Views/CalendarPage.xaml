<Page
    x:Class="Calender.Views.CalendarPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Calender.Models"
    Background="Transparent">

    <Grid Padding="24,16,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- month nav bar    -->
            <RowDefinition Height="Auto"/>   <!-- day-name headers -->
            <RowDefinition Height="*"/>      <!-- 6-week grid      -->
        </Grid.RowDefinitions>

        <!-- ── Month navigation ──────────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>    <!-- month title    -->
                <ColumnDefinition Width="Auto"/> <!-- New Event btn  -->
                <ColumnDefinition Width="Auto"/> <!-- previous month -->
                <ColumnDefinition Width="Auto"/> <!-- Today          -->
                <ColumnDefinition Width="Auto"/> <!-- next month     -->
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Text="{x:Bind ViewModel.MonthYearDisplay, Mode=OneWay}"
                Style="{StaticResource TitleLargeTextBlockStyle}"
                VerticalAlignment="Center"/>

            <!-- New Event — Ctrl+N -->
            <Button Grid.Column="1"
                    Command="{x:Bind ViewModel.RequestNewEventCommand}"
                    Margin="0,0,12,0"
                    Style="{StaticResource AccentButtonStyle}"
                    ToolTipService.ToolTip="New event  (Ctrl+N)"
                    PointerEntered="NavBtn_PointerEntered"
                    PointerExited="NavBtn_PointerExited">
                <Button.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Control" Key="N"/>
                </Button.KeyboardAccelerators>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE710;" FontSize="12"/>
                    <TextBlock Text="New event" FontSize="13"/>
                </StackPanel>
            </Button>

            <!-- Previous month — Ctrl+Left -->
            <Button Grid.Column="2"
                    Command="{x:Bind ViewModel.PreviousMonthCommand}"
                    Margin="0,0,4,0"
                    ToolTipService.ToolTip="Previous month  (Ctrl+Left)"
                    PointerEntered="NavBtn_PointerEntered"
                    PointerExited="NavBtn_PointerExited">
                <Button.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Control" Key="Left"/>
                </Button.KeyboardAccelerators>
                <FontIcon Glyph="&#xE76B;" FontSize="14"/>
            </Button>

            <!-- Today — T -->
            <Button Grid.Column="3"
                    Command="{x:Bind ViewModel.GoToTodayCommand}"
                    Margin="0,0,4,0"
                    Padding="10,5"
                    ToolTipService.ToolTip="Jump to today  (T)"
                    PointerEntered="NavBtn_PointerEntered"
                    PointerExited="NavBtn_PointerExited">
                <Button.KeyboardAccelerators>
                    <KeyboardAccelerator Key="T"/>
                </Button.KeyboardAccelerators>
                <TextBlock Text="Today" FontSize="12"/>
            </Button>

            <!-- Next month — Ctrl+Right -->
            <Button Grid.Column="4"
                    Command="{x:Bind ViewModel.NextMonthCommand}"
                    ToolTipService.ToolTip="Next month  (Ctrl+Right)"
                    PointerEntered="NavBtn_PointerEntered"
                    PointerExited="NavBtn_PointerExited">
                <Button.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Control" Key="Right"/>
                </Button.KeyboardAccelerators>
                <FontIcon Glyph="&#xE76C;" FontSize="14"/>
            </Button>
        </Grid>

        <!-- ── Day-name headers ──────────────────────────────────────────── -->
        <Grid Grid.Row="1" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="SUN" HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Grid.Column="1" Text="MON" HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Grid.Column="2" Text="TUE" HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Grid.Column="3" Text="WED" HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Grid.Column="4" Text="THU" HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Grid.Column="5" Text="FRI" HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Grid.Column="6" Text="SAT" HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>

        <!-- ── 6-week calendar grid ──────────────────────────────────────── -->
        <Grid Grid.Row="2" x:Name="CalendarGrid">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="CalendarSlide"/>
            </Grid.RenderTransform>

            <ItemsRepeater ItemsSource="{x:Bind ViewModel.CalendarDays, Mode=OneWay}">

                <ItemsRepeater.Layout>
                    <UniformGridLayout
                        MaximumRowsOrColumns="7"
                        Orientation="Horizontal"
                        ItemsStretch="Fill"
                        MinColumnSpacing="0"
                        MinRowSpacing="0"/>
                </ItemsRepeater.Layout>

                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:CalendarDay">

                        <Border
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,1,1,0"
                            MinHeight="90"
                            Tag="{x:Bind Date}"
                            Tapped="DayCell_Tapped">
                            <Border.Transitions>
                                <TransitionCollection>
                                    <EntranceThemeTransition IsStaggeringEnabled="False"/>
                                </TransitionCollection>
                            </Border.Transitions>

                            <Grid>
                                <!-- Weekend tint — sits behind all content, not hit-testable -->
                                <Rectangle
                                    IsHitTestVisible="False"
                                    Opacity="0.45"
                                    Visibility="{x:Bind IsWeekend,
                                        Converter={StaticResource BoolToVisibilityConverter},
                                        Mode=OneTime}">
                                    <Rectangle.Fill>
                                        <SolidColorBrush Color="{ThemeResource SystemBaseLowColor}"/>
                                    </Rectangle.Fill>
                                </Rectangle>

                                <!-- Cell content -->
                                <StackPanel Padding="5,4">

                                    <!-- Day number badge -->
                                    <Border
                                        Width="26" Height="26"
                                        CornerRadius="13"
                                        HorizontalAlignment="Left"
                                        Background="{x:Bind IsToday,
                                            Converter={StaticResource BoolToAccentBrushConverter},
                                            Mode=OneTime}">
                                        <TextBlock
                                            Text="{x:Bind Date.Day}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Opacity="{x:Bind IsCurrentMonth,
                                                Converter={StaticResource BoolToOpacityConverter},
                                                Mode=OneTime}"/>
                                    </Border>

                                    <!-- Event chips — scrollable, shows all events -->
                                    <ScrollViewer
                                        MaxHeight="58"
                                        VerticalScrollBarVisibility="Auto"
                                        HorizontalScrollBarVisibility="Disabled"
                                        Margin="0,2,0,0">
                                        <ItemsRepeater
                                            ItemsSource="{x:Bind Events, Mode=OneWay}">
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="models:CalendarEvent">
                                                    <Button
                                                        HorizontalAlignment="Stretch"
                                                        Padding="4,2"
                                                        Margin="0,1"
                                                        Tag="{x:Bind}"
                                                        Tapped="ChipButton_Tapped"
                                                        ToolTipService.ToolTip="{x:Bind ChipTooltip}"
                                                        Background="Transparent"
                                                        BorderThickness="0">
                                                        <Button.ContextFlyout>
                                                            <MenuFlyout>
                                                                <MenuFlyoutItem
                                                                    Text="Edit"
                                                                    Tag="{x:Bind}"
                                                                    Click="ChipEdit_Click">
                                                                    <MenuFlyoutItem.Icon>
                                                                        <FontIcon Glyph="&#xE70F;"/>
                                                                    </MenuFlyoutItem.Icon>
                                                                </MenuFlyoutItem>
                                                                <MenuFlyoutSeparator/>
                                                                <MenuFlyoutItem
                                                                    Text="Delete"
                                                                    Tag="{x:Bind}"
                                                                    Click="ChipDelete_Click">
                                                                    <MenuFlyoutItem.Icon>
                                                                        <FontIcon Glyph="&#xE74D;"
                                                                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                                                    </MenuFlyoutItem.Icon>
                                                                </MenuFlyoutItem>
                                                            </MenuFlyout>
                                                        </Button.ContextFlyout>
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <Ellipse
                                                                Width="7" Height="7"
                                                                VerticalAlignment="Center"
                                                                Fill="{x:Bind Color,
                                                                    Converter={StaticResource StringToColorConverter}}"/>
                                                            <TextBlock
                                                                Text="{x:Bind Title}"
                                                                FontSize="11"
                                                                TextTrimming="CharacterEllipsis"
                                                                MaxLines="1"
                                                                VerticalAlignment="Center"/>
                                                            <!-- Arrow indicator for multi-day events -->
                                                            <TextBlock
                                                                Text="→"
                                                                FontSize="9"
                                                                Opacity="0.6"
                                                                VerticalAlignment="Center"
                                                                Visibility="{x:Bind IsMultiDay,
                                                                    Converter={StaticResource BoolToVisibilityConverter},
                                                                    Mode=OneTime}"/>
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>
                                    </ScrollViewer>

                                </StackPanel>
                            </Grid>
                        </Border>

                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>

            </ItemsRepeater>
        </Grid><!-- /CalendarGrid -->
    </Grid>
</Page>
