<Page
    x:Class="Calender.Views.CalendarPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Calender.Models"
    Background="Transparent">

    <Grid Padding="24,16,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- month nav bar    -->
            <RowDefinition Height="Auto"/>   <!-- day-name headers -->
            <RowDefinition Height="*"/>      <!-- 6-week grid      -->
        </Grid.RowDefinitions>

        <!-- ── Month navigation ──────────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>    <!-- month title    -->
                <ColumnDefinition Width="Auto"/> <!-- New Event btn  -->
                <ColumnDefinition Width="Auto"/> <!-- previous month -->
                <ColumnDefinition Width="Auto"/> <!-- next month     -->
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Text="{x:Bind ViewModel.MonthYearDisplay, Mode=OneWay}"
                Style="{StaticResource TitleLargeTextBlockStyle}"
                VerticalAlignment="Center"/>

            <Button Grid.Column="1"
                    Command="{x:Bind ViewModel.RequestNewEventCommand}"
                    Margin="0,0,12,0"
                    Style="{StaticResource AccentButtonStyle}"
                    ToolTipService.ToolTip="New event">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE710;" FontSize="12"/>
                    <TextBlock Text="New event" FontSize="13"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="2"
                    Command="{x:Bind ViewModel.PreviousMonthCommand}"
                    Margin="0,0,8,0"
                    ToolTipService.ToolTip="Previous month">
                <FontIcon Glyph="&#xE76B;" FontSize="14"/>
            </Button>

            <Button Grid.Column="3"
                    Command="{x:Bind ViewModel.NextMonthCommand}"
                    ToolTipService.ToolTip="Next month">
                <FontIcon Glyph="&#xE76C;" FontSize="14"/>
            </Button>
        </Grid>

        <!-- ── Day-name headers ──────────────────────────────────────────── -->
        <Grid Grid.Row="1" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="SUN" HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Grid.Column="1" Text="MON" HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Grid.Column="2" Text="TUE" HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Grid.Column="3" Text="WED" HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Grid.Column="4" Text="THU" HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Grid.Column="5" Text="FRI" HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Grid.Column="6" Text="SAT" HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>

        <!-- ── 6-week calendar grid ──────────────────────────────────────── -->
        <!--
            CalendarGrid is named so the animation code-behind can target its
            TranslateTransform when the displayed month changes.
        -->
        <Grid Grid.Row="2" x:Name="CalendarGrid">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="CalendarSlide"/>
            </Grid.RenderTransform>

        <ItemsRepeater
            ItemsSource="{x:Bind ViewModel.CalendarDays, Mode=OneWay}">

            <ItemsRepeater.Layout>
                <UniformGridLayout
                    MaximumRowsOrColumns="7"
                    Orientation="Horizontal"
                    ItemsStretch="Fill"
                    MinColumnSpacing="0"
                    MinRowSpacing="0"/>
            </ItemsRepeater.Layout>

            <ItemsRepeater.ItemTemplate>
                <DataTemplate x:DataType="models:CalendarDay">
                    <Border
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="0,1,1,0"
                        MinHeight="90"
                        Padding="5,4">
                        <StackPanel>

                            <!-- Day number badge -->
                            <Border
                                Width="26" Height="26"
                                CornerRadius="13"
                                HorizontalAlignment="Left"
                                Background="{x:Bind IsToday,
                                    Converter={StaticResource BoolToAccentBrushConverter},
                                    Mode=OneTime}">
                                <TextBlock
                                    Text="{x:Bind Date.Day}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Opacity="{x:Bind IsCurrentMonth,
                                        Converter={StaticResource BoolToOpacityConverter},
                                        Mode=OneTime}"/>
                            </Border>

                            <!-- Event chips (up to 3 visible) -->
                            <ItemsRepeater
                                ItemsSource="{x:Bind VisibleEvents, Mode=OneWay}"
                                Margin="0,2,0,0">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="models:CalendarEvent">
                                        <Button
                                            HorizontalAlignment="Stretch"
                                            Padding="4,2"
                                            Margin="0,1"
                                            Tag="{x:Bind}"
                                            Tapped="ChipButton_Tapped"
                                            Background="Transparent"
                                            BorderThickness="0">
                                            <Button.ContextFlyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem
                                                        Text="Edit"
                                                        Tag="{x:Bind}"
                                                        Click="ChipEdit_Click">
                                                        <MenuFlyoutItem.Icon>
                                                            <FontIcon Glyph="&#xE70F;"/>
                                                        </MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                    <MenuFlyoutSeparator/>
                                                    <MenuFlyoutItem
                                                        Text="Delete"
                                                        Tag="{x:Bind}"
                                                        Click="ChipDelete_Click">
                                                        <MenuFlyoutItem.Icon>
                                                            <FontIcon Glyph="&#xE74D;"
                                                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                                        </MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                </MenuFlyout>
                                            </Button.ContextFlyout>
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <Ellipse
                                                    Width="7" Height="7"
                                                    VerticalAlignment="Center"
                                                    Fill="{x:Bind Color,
                                                        Converter={StaticResource StringToColorConverter}}"/>
                                                <TextBlock
                                                    Text="{x:Bind Title}"
                                                    FontSize="11"
                                                    TextTrimming="CharacterEllipsis"
                                                    MaxLines="1"
                                                    VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>

                            <!-- "+N more" overflow label -->
                            <TextBlock
                                Text="{x:Bind OverflowLabel, Mode=OneWay}"
                                FontSize="10"
                                Margin="4,1,0,0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Visibility="{x:Bind HasOverflow,
                                    Converter={StaticResource BoolToVisibilityConverter},
                                    Mode=OneWay}"/>

                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsRepeater.ItemTemplate>

        </ItemsRepeater>
        </Grid><!-- /CalendarGrid -->
    </Grid>
</Page>
