<Page
    x:Class="Calender.Views.AgendaPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Calender.Views"
    xmlns:vm="using:Calender.ViewModels"
    xmlns:models="using:Calender.Models"
    Background="Transparent">

    <Page.Resources>

        <!-- ── Template selector ──────────────────────────────────────────── -->
        <local:AgendaTemplateSelector x:Key="AgendaSelector">

            <local:AgendaTemplateSelector.HeaderTemplate>
                <DataTemplate x:DataType="vm:AgendaHeader">
                    <TextBlock
                        Text="{x:Bind Display}"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Opacity="{x:Bind HeaderOpacity}"
                        Margin="0,18,0,4"/>
                </DataTemplate>
            </local:AgendaTemplateSelector.HeaderTemplate>

            <local:AgendaTemplateSelector.EventTemplate>
                <DataTemplate x:DataType="models:CalendarEvent">
                    <Grid Padding="4,5,4,5" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Ellipse
                            Grid.Column="0"
                            Width="8" Height="8"
                            VerticalAlignment="Center"
                            Fill="{x:Bind Color, Converter={StaticResource StringToColorConverter}}"/>

                        <StackPanel Grid.Column="1">
                            <TextBlock
                                Text="{x:Bind Title}"
                                FontSize="13"
                                TextTrimming="CharacterEllipsis"
                                MaxLines="1"/>
                            <TextBlock
                                Text="{x:Bind StartTimeShort}"
                                FontSize="11"
                                Opacity="0.55"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </local:AgendaTemplateSelector.EventTemplate>

        </local:AgendaTemplateSelector>

    </Page.Resources>

    <Grid Padding="24,16,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- page title  -->
            <RowDefinition Height="*"/>    <!-- content     -->
        </Grid.RowDefinitions>

        <!-- ── Page title ─────────────────────────────────────────────────── -->
        <TextBlock
            Grid.Row="0"
            Text="Agenda"
            Style="{StaticResource TitleLargeTextBlockStyle}"
            Margin="0,0,0,16"/>

        <!-- ── Empty state ────────────────────────────────────────────────── -->
        <StackPanel
            Grid.Row="1"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            Spacing="12"
            Visibility="{x:Bind ViewModel.IsEmpty,
                Converter={StaticResource BoolToVisibilityConverter},
                Mode=OneWay}">
            <FontIcon Glyph="&#xE8D1;" FontSize="48" Opacity="0.25"
                      HorizontalAlignment="Center"/>
            <TextBlock
                Text="No events in the next 60 days"
                Opacity="0.45"
                HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- ── Event list ─────────────────────────────────────────────────── -->
        <ScrollViewer
            Grid.Row="1"
            Visibility="{x:Bind ViewModel.IsEmpty,
                Converter={StaticResource BoolToVisibilityConverter},
                ConverterParameter=Invert,
                Mode=OneWay}">
            <ItemsRepeater
                ItemsSource="{x:Bind ViewModel.Rows, Mode=OneWay}"
                ItemTemplate="{StaticResource AgendaSelector}"
                Margin="0,0,0,24"/>
        </ScrollViewer>

    </Grid>
</Page>
