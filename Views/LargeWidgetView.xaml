<Page
    x:Class="Calender.Views.LargeWidgetView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Calender.Models"
    Background="Transparent">

    <StackPanel Padding="14,6,14,14" Spacing="8">

        <!-- ── Mini-calendar header ───────────────────────────────────────── -->
        <TextBlock
            Text="{x:Bind ViewModel.MonthYearDisplay, Mode=OneWay}"
            FontSize="13"
            FontWeight="SemiBold"/>

        <!-- ── Day-name row ───────────────────────────────────────────────── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="S" HorizontalAlignment="Center" FontSize="10" Opacity="0.45"/>
            <TextBlock Grid.Column="1" Text="M" HorizontalAlignment="Center" FontSize="10" Opacity="0.45"/>
            <TextBlock Grid.Column="2" Text="T" HorizontalAlignment="Center" FontSize="10" Opacity="0.45"/>
            <TextBlock Grid.Column="3" Text="W" HorizontalAlignment="Center" FontSize="10" Opacity="0.45"/>
            <TextBlock Grid.Column="4" Text="T" HorizontalAlignment="Center" FontSize="10" Opacity="0.45"/>
            <TextBlock Grid.Column="5" Text="F" HorizontalAlignment="Center" FontSize="10" Opacity="0.45"/>
            <TextBlock Grid.Column="6" Text="S" HorizontalAlignment="Center" FontSize="10" Opacity="0.45"/>
        </Grid>

        <!-- ── 6-week mini grid ───────────────────────────────────────────── -->
        <ItemsRepeater ItemsSource="{x:Bind ViewModel.CalendarDays, Mode=OneWay}">
            <ItemsRepeater.Layout>
                <UniformGridLayout
                    MaximumRowsOrColumns="7"
                    Orientation="Horizontal"
                    ItemsStretch="Fill"
                    MinColumnSpacing="0"
                    MinRowSpacing="0"/>
            </ItemsRepeater.Layout>
            <ItemsRepeater.ItemTemplate>
                <DataTemplate x:DataType="models:CalendarDay">
                    <StackPanel MinHeight="32" VerticalAlignment="Top"
                                HorizontalAlignment="Center" Spacing="1" Padding="0,2">

                        <!-- Day number badge -->
                        <Border
                            Width="22" Height="22"
                            CornerRadius="11"
                            HorizontalAlignment="Center"
                            Background="{x:Bind IsToday,
                                Converter={StaticResource BoolToAccentBrushConverter},
                                Mode=OneTime}">
                            <TextBlock
                                Text="{x:Bind Date.Day}"
                                FontSize="11"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Opacity="{x:Bind IsCurrentMonth,
                                    Converter={StaticResource BoolToOpacityConverter},
                                    Mode=OneTime}"/>
                        </Border>

                        <!-- Event-present dot -->
                        <Ellipse
                            Width="4" Height="4"
                            HorizontalAlignment="Center"
                            Fill="{ThemeResource AccentFillColorDefaultBrush}"
                            Visibility="{x:Bind HasOverflow,
                                Converter={StaticResource BoolToVisibilityConverter},
                                Mode=OneWay}"/>
                    </StackPanel>
                </DataTemplate>
            </ItemsRepeater.ItemTemplate>
        </ItemsRepeater>

        <!-- ── Divider ────────────────────────────────────────────────────── -->
        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,2"/>

        <!-- ── Today's events ─────────────────────────────────────────────── -->
        <StackPanel Spacing="5">
            <TextBlock
                Text="TODAY"
                FontSize="10"
                FontWeight="SemiBold"
                Opacity="0.45"
                CharacterSpacing="60"/>

            <ItemsRepeater ItemsSource="{x:Bind ViewModel.TodayEvents, Mode=OneWay}">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:CalendarEvent">
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                            <Ellipse
                                Width="7" Height="7"
                                VerticalAlignment="Center"
                                Fill="{x:Bind Color, Converter={StaticResource StringToColorConverter}}"/>
                            <StackPanel>
                                <TextBlock
                                    Text="{x:Bind Title}"
                                    FontSize="12"
                                    TextTrimming="CharacterEllipsis"
                                    MaxLines="1"/>
                                <TextBlock
                                    Text="{x:Bind StartTimeShort}"
                                    FontSize="10"
                                    Opacity="0.55"/>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </StackPanel>

    </StackPanel>
</Page>
